@model MostafaSaidPortfolio.Domain.Entities.Event
@{
    ViewData["Title"] = Model.Title;
    var isUpcoming = Model.EventDate >= DateTime.UtcNow;
}

<!-- Page Header -->
<section class="page-header">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-2 mb-4">
            <a asp-controller="Events" asp-action="Index"
               class="text-indigo-400 hover:text-indigo-300 text-sm font-medium flex items-center gap-1 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                @L["Events_BackToEvents"]
            </a>
        </div>
        <div class="flex items-center gap-3 mb-4">
            @if (isUpcoming)
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-500/20 border border-emerald-400/30 rounded-full text-emerald-300 text-xs font-semibold">
                    <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                    @L["Events_UpcomingBadge"]
                </span>
            }
            else
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-500/20 border border-slate-400/30 rounded-full text-slate-300 text-xs font-semibold">
                    @L["Events_PastBadge"]
                </span>
            }
            @if (Model.IsFeatured)
            {
                <span class="px-3 py-1 bg-amber-400 text-amber-900 text-xs font-bold rounded-full">@L["Common_Featured"]</span>
            }
        </div>
        <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-4">@Model.Title</h1>
        <div class="flex flex-wrap items-center gap-5 text-slate-400 text-sm">
            <span class="flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                @Model.EventDate.ToString("dddd, MMMM d, yyyy")
            </span>
            <span class="flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                @Model.EventDate.ToString("h:mm tt") @(Model.EventEndDate.HasValue ? "– " + Model.EventEndDate.Value.ToString("h:mm tt") : "")
            </span>
            @if (!string.IsNullOrEmpty(Model.Location))
            {
                <span class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    @Model.Location
                </span>
            }
        </div>
    </div>
</section>

<!-- Content -->
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-3 gap-10">

        <!-- Main Description -->
        <div class="lg:col-span-2">
            <h2 class="font-heading text-xl font-bold mb-4" style="color:var(--text-primary)">@L["Events_AboutEvent"]</h2>
            <div class="prose max-w-none text-base leading-relaxed" style="color:var(--text-secondary)">
                <p>@Model.Description</p>
            </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-5">

            <!-- Registration card -->
            <div class="content-card p-5">
                <h3 class="font-heading font-bold text-base mb-4" style="color:var(--text-primary)">@L["Events_Registration"]</h3>
                <dl class="space-y-3 text-sm mb-5">
                    <div class="flex justify-between">
                        <dt style="color:var(--text-muted)">@L["Events_Date"]</dt>
                        <dd class="font-medium text-right" style="color:var(--text-primary)">@Model.EventDate.ToString("MMM d, yyyy")</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt style="color:var(--text-muted)">@L["Events_Time"]</dt>
                        <dd class="font-medium" style="color:var(--text-primary)">@Model.EventDate.ToString("h:mm tt")</dd>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <div class="flex justify-between">
                            <dt style="color:var(--text-muted)">@L["Events_Location"]</dt>
                            <dd class="font-medium text-right" style="color:var(--text-primary)">@Model.Location</dd>
                        </div>
                    }
                    @if (Model.MaxAttendees.HasValue)
                    {
                        <div class="flex justify-between">
                            <dt style="color:var(--text-muted)">@L["Events_Capacity"]</dt>
                            <dd class="font-medium" style="color:var(--text-primary)">@Model.RegisteredCount / @Model.MaxAttendees</dd>
                        </div>
                        <div>
                            <div class="h-1.5 rounded-full mb-1" style="background:var(--bg-subtle)">
                                <div class="h-1.5 rounded-full bg-indigo-500 transition-all"
                                     style="width:@(Math.Min(100, (int)((double)Model.RegisteredCount / Model.MaxAttendees * 100)))%"></div>
                            </div>
                        </div>
                    }
                </dl>

                @if (isUpcoming)
                {
                    @if (Model.HasAvailableSpots)
                    {
                        <a asp-controller="Events" asp-action="Register" asp-route-id="@Model.Id"
                           class="block w-full text-center py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-colors text-sm">
                            @L["Events_Register"]
                        </a>
                    }
                    else
                    {
                        <div class="block w-full text-center py-3 bg-slate-200 text-slate-400 font-semibold rounded-xl text-sm cursor-not-allowed">
                            @L["Events_Full"]
                        </div>
                    }
                }
                else
                {
                    <div class="block w-full text-center py-3 rounded-xl text-sm font-semibold" style="background:var(--bg-subtle);color:var(--text-muted)">
                        @L["Events_EventEnded"]
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.EventUrl))
            {
                <a href="@Model.EventUrl" target="_blank" rel="noopener"
                   class="content-card p-4 flex items-center gap-3 text-sm font-semibold group hover:border-indigo-300 transition-colors"
                   style="color:var(--accent)">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    @L["Events_VisitLink"]
                </a>
            }
        </aside>
    </div>
</div>
