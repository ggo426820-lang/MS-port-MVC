@model MostafaSaidPortfolio.Domain.ViewModels.Projects.ProjectListViewModel
@using MostafaSaidPortfolio.Domain.Entities
@{
    ViewData["Title"] = L["Projects_Title"].ToString();

    string Q(string? overrideQ = null, string? overrideCat = null, string? overrideSort = null, int overridePage = 1)
    {
        var q    = overrideQ    ?? Model.Search;
        var cat  = overrideCat  ?? Model.CategorySlug;
        var sort = overrideSort ?? Model.Sort;
        var parts = new System.Collections.Generic.List<string>();
        if (!string.IsNullOrWhiteSpace(q))    parts.Add($"q={Uri.EscapeDataString(q)}");
        if (!string.IsNullOrWhiteSpace(cat))  parts.Add($"categorySlug={Uri.EscapeDataString(cat)}");
        if (sort != "newest")                 parts.Add($"sort={sort}");
        if (overridePage > 1)                 parts.Add($"page={overridePage}");
        return parts.Count > 0 ? "?" + string.Join("&", parts) : "?";
    }
}

<!-- Page Header -->
<section class="page-header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-indigo-400 font-semibold text-xs uppercase tracking-widest mb-3">@L["Projects_Label"]</p>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white mb-4">@L["Projects_Title"]</h1>
        <p class="text-slate-400 text-lg max-w-xl">@L["Projects_Description"]</p>
    </div>
</section>

<!-- Filter + Grid -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- ── Search + Sort bar ── -->
    <form method="get" action="" class="flex flex-col sm:flex-row gap-3 mb-6">
        <div class="relative flex-1">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 pointer-events-none" style="color:var(--text-muted)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" name="q" value="@Model.Search" placeholder="@L["Projects_SearchPlaceholder"]"
                   class="w-full pl-10 pr-4 py-2.5 rounded-xl border text-sm outline-none transition-all"
                   style="background:var(--bg-surface);border-color:var(--border-subtle);color:var(--text-primary)"/>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.CategorySlug))
        {
            <input type="hidden" name="categorySlug" value="@Model.CategorySlug"/>
        }
        <input type="hidden" name="sort" value="@Model.Sort"/>
        <button type="submit"
                class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl transition-colors shrink-0">
            @L["Common_Search"]
        </button>
    </form>

    <!-- ── Category filter pills ── -->
    @if (Model.Categories.Any())
    {
        <div class="flex flex-wrap gap-2 mb-6">
            <a href="@Q(overrideCat: "", overridePage: 1)"
               class="px-4 py-1.5 rounded-full text-sm font-medium border transition-colors @(Model.CategoryId == null ? "bg-indigo-600 text-white border-indigo-600" : "border-current hover:border-indigo-500 hover:text-indigo-500")"
               style="@(Model.CategoryId == null ? "" : "color:var(--text-secondary);border-color:var(--border-subtle)")">
                @L["Common_All"]
            </a>
            @foreach (var cat in Model.Categories)
            {
                var isActive = Model.CategorySlug == cat.Slug;
                <a href="@Q(overrideCat: cat.Slug, overridePage: 1)"
                   class="px-4 py-1.5 rounded-full text-sm font-medium border transition-colors @(isActive ? "bg-indigo-600 text-white border-indigo-600" : "hover:border-indigo-500 hover:text-indigo-500")"
                   style="@(isActive ? "" : "color:var(--text-secondary);border-color:var(--border-subtle)")">
                    @cat.Name
                </a>
            }
        </div>
    }

    <!-- ── Sort + count row ── -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-8">
        <p class="text-sm" style="color:var(--text-muted)">
            @if (Model.Projects.TotalCount > 0)
            {
                <span>@Model.Projects.FirstItem–@Model.Projects.LastItem @L["Common_Of"] @Model.Projects.TotalCount @L["Projects_Projects"]</span>
            }
            else
            {
                <span>@L["Projects_NoProjects"]</span>
            }
        </p>
        <form method="get" action="" class="flex items-center gap-2">
            @if (!string.IsNullOrWhiteSpace(Model.Search))      { <input type="hidden" name="q"            value="@Model.Search"/> }
            @if (!string.IsNullOrWhiteSpace(Model.CategorySlug)){ <input type="hidden" name="categorySlug" value="@Model.CategorySlug"/> }
            <label class="text-sm shrink-0" style="color:var(--text-muted)">@L["Common_SortBy"]</label>
            <select name="sort" onchange="this.form.submit()"
                    class="text-sm rounded-lg border px-3 py-1.5 outline-none transition-all"
                    style="background:var(--bg-surface);border-color:var(--border-subtle);color:var(--text-primary)">
                <option value="newest"  selected="@(Model.Sort == "newest"  ? "selected" : null)">@L["Sort_Newest"]</option>
                <option value="oldest"  selected="@(Model.Sort == "oldest"  ? "selected" : null)">@L["Sort_Oldest"]</option>
                <option value="popular" selected="@(Model.Sort == "popular" ? "selected" : null)">@L["Sort_Popular"]</option>
                <option value="title"   selected="@(Model.Sort == "title"   ? "selected" : null)">@L["Sort_Title"]</option>
            </select>
        </form>
    </div>

    <!-- ── Projects Grid ── -->
    @if (Model.Projects.Items.Any())
    {
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var project in Model.Projects.Items)
            {
                <div class="content-card group flex flex-col observe-fade">

                    <!-- Image / Placeholder -->
                    <div class="relative h-44 overflow-hidden" style="background:linear-gradient(135deg,var(--accent-bg),#f3e8ff)">
                        @if (!string.IsNullOrEmpty(project.ImageUrl))
                        {
                            <img src="@project.ImageUrl" alt="@project.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                        }
                        else
                        {
                            <div class="absolute inset-0 flex items-center justify-center">
                                <div class="w-16 h-16 rounded-2xl shadow-md flex items-center justify-center" style="background:var(--bg-surface)">
                                    <svg class="w-8 h-8" style="color:var(--accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                                    </svg>
                                </div>
                            </div>
                        }
                        @if (project.IsFeatured)
                        {
                            <span class="absolute top-3 left-3 px-2.5 py-1 bg-amber-400 text-amber-900 text-xs font-bold rounded-full">@L["Common_Featured"]</span>
                        }
                        @if (!string.IsNullOrEmpty(project.CategoryName ?? project.Category?.Name))
                        {
                            <span class="absolute top-3 right-3 px-2.5 py-1 bg-white/90 backdrop-blur-sm text-indigo-700 text-xs font-semibold rounded-full">
                                @(project.CategoryName ?? project.Category?.Name)
                            </span>
                        }
                    </div>

                    <div class="p-6 flex flex-col flex-1">
                        <h3 class="card-title font-heading font-bold text-lg leading-tight mb-2 group-hover:text-indigo-500 transition-colors">@project.Title</h3>
                        <p class="card-text text-sm leading-relaxed mb-4 flex-1">
                            @(project.Description.Length > 130 ? project.Description[..130] + "…" : project.Description)
                        </p>

                        @if (project.TechStackList.Any())
                        {
                            <div class="flex flex-wrap gap-1.5 mb-4">
                                @foreach (var tech in project.TechStackList.Take(4))
                                {
                                    <span class="tech-chip">@tech</span>
                                }
                                @if (project.TechStackList.Length > 4)
                                {
                                    <span class="tech-chip">+@(project.TechStackList.Length - 4)</span>
                                }
                            </div>
                        }

                        <!-- Actions row -->
                        <div class="flex items-center justify-between pt-4 border-t card-divider">
                            <div class="flex items-center gap-3 text-xs" style="color:var(--text-muted)">
                                <span class="flex items-center gap-1">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    @project.ViewCount
                                </span>
                                <span class="flex items-center gap-1">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                                    @project.LikeCount
                                </span>
                            </div>
                            <div class="flex gap-2">
                                @if (!string.IsNullOrEmpty(project.GitHubUrl))
                                {
                                    <a href="@project.GitHubUrl" target="_blank" rel="noopener"
                                       class="p-1.5 rounded-lg transition-colors hover:bg-opacity-10" style="color:var(--text-secondary)" title="GitHub">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(project.LiveUrl))
                                {
                                    <a href="@project.LiveUrl" target="_blank" rel="noopener"
                                       class="p-1.5 rounded-lg transition-colors" style="color:var(--accent)" title="Live Demo">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                                    </a>
                                }
                                <a href="@Url.Action("Details", "Projects", new { id = project.Slug })"
                                   class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold rounded-lg transition-colors">
                                    @L["Projects_Details"]
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ── Pagination ── -->
        @if (Model.Projects.TotalPages > 1)
        {
            <nav class="flex justify-center items-center gap-1.5 mt-12" aria-label="Pagination">
                @if (Model.Projects.HasPreviousPage)
                {
                    <a href="@Q(overridePage: Model.Page - 1)"
                       class="px-3.5 py-2 rounded-lg border text-sm font-medium transition-colors hover:border-indigo-500 hover:text-indigo-500"
                       style="border-color:var(--border-subtle);color:var(--text-secondary)">
                        ←
                    </a>
                }
                @for (int i = 1; i <= Model.Projects.TotalPages; i++)
                {
                    var isCurrentPage = i == Model.Page;
                    <a href="@Q(overridePage: i)"
                       class="px-3.5 py-2 rounded-lg border text-sm font-medium transition-colors @(isCurrentPage ? "bg-indigo-600 text-white border-indigo-600" : "hover:border-indigo-500 hover:text-indigo-500")"
                       style="@(isCurrentPage ? "" : "border-color:var(--border-subtle);color:var(--text-secondary)")"
                       aria-current="@(isCurrentPage ? "page" : null)">
                        @i
                    </a>
                }
                @if (Model.Projects.HasNextPage)
                {
                    <a href="@Q(overridePage: Model.Page + 1)"
                       class="px-3.5 py-2 rounded-lg border text-sm font-medium transition-colors hover:border-indigo-500 hover:text-indigo-500"
                       style="border-color:var(--border-subtle);color:var(--text-secondary)">
                        →
                    </a>
                }
            </nav>
        }
    }
    else
    {
        <div class="text-center py-24">
            <div class="w-16 h-16 mx-auto mb-4 rounded-2xl flex items-center justify-center" style="background:var(--accent-bg)">
                <svg class="w-8 h-8" style="color:var(--accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                </svg>
            </div>
            <h3 class="font-heading font-bold text-xl mb-2" style="color:var(--text-primary)">
                @(Model.HasFilters ? L["Projects_NoResults"] : L["Projects_Empty"])
            </h3>
            <p class="mb-4" style="color:var(--text-muted)">
                @(Model.HasFilters ? L["Projects_NoResultsSub"] : L["Projects_EmptySub"])
            </p>
            @if (Model.HasFilters)
            {
                <a href="?" class="inline-flex items-center gap-1.5 text-sm font-semibold" style="color:var(--accent)">
                    @L["Common_ClearFilters"] →
                </a>
            }
        </div>
    }
</section>
