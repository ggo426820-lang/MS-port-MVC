@model Project
@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.Description;
}

<!-- Page Header -->
<section class="page-header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @if (!string.IsNullOrEmpty(Model.CategoryName ?? Model.Category?.Name))
        {
            <span class="inline-block tag-badge mb-4 border-indigo-400/30 bg-indigo-500/20 text-indigo-300">
                @(Model.CategoryName ?? Model.Category?.Name)
            </span>
        }
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white mb-4">@Model.Title</h1>
        <div class="flex items-center gap-4 text-slate-400 text-sm">
            <span>@Model.CreatedAt.ToString("MMMM yyyy")</span>
            @if (Model.IsFeatured)
            {
                <span class="px-2.5 py-0.5 bg-amber-400/20 border border-amber-400/30 text-amber-300 rounded-full text-xs font-semibold">★ Featured</span>
            }
        </div>
    </div>
</section>

<!-- Project Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-3 gap-12">

        <!-- Main Content -->
        <div class="lg:col-span-2">

            <!-- Image -->
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-8 rounded-2xl overflow-hidden shadow-lg">
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="w-full h-64 sm:h-80 object-cover" />
                </div>
            }
            else
            {
                <div class="mb-8 h-52 rounded-2xl bg-gradient-to-br from-indigo-50 to-purple-50 border border-indigo-100 flex items-center justify-center">
                    <div class="w-16 h-16 rounded-2xl bg-white shadow flex items-center justify-center">
                        <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                        </svg>
                    </div>
                </div>
            }

            <!-- Description -->
            <div class="prose max-w-none mb-8">
                @if (!string.IsNullOrEmpty(Model.LongDescription))
                {
                    <p class="text-lg text-slate-700 leading-relaxed">@Model.LongDescription</p>
                }
                else
                {
                    <p class="text-lg text-slate-700 leading-relaxed">@Model.Description</p>
                }
            </div>

            <!-- Tech Stack -->
            @if (Model.TechStackList.Any())
            {
                <div class="mb-8">
                    <h3 class="font-heading font-bold text-slate-900 text-lg mb-4">Technology Stack</h3>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var tech in Model.TechStackList)
                        {
                            <span class="px-3 py-1.5 bg-slate-100 border border-slate-200 text-slate-700 rounded-lg text-sm font-medium">@tech</span>
                        }
                    </div>
                </div>
            }

            <!-- Actions -->
            <div class="flex flex-wrap gap-4 pt-6 border-t border-slate-200">
                @if (!string.IsNullOrEmpty(Model.LiveUrl))
                {
                    <a href="@Model.LiveUrl" target="_blank" rel="noopener"
                       class="btn-primary">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        View Live Demo
                    </a>
                }
                @if (!string.IsNullOrEmpty(Model.GitHubUrl))
                {
                    <a href="@Model.GitHubUrl" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 px-6 py-3 border border-slate-200 hover:border-slate-300 text-slate-700 font-semibold rounded-xl transition-colors">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                        View on GitHub
                    </a>
                }
                <a asp-action="Index"
                   class="inline-flex items-center gap-2 px-6 py-3 border border-slate-200 hover:border-slate-300 text-slate-600 rounded-xl transition-colors text-sm">
                    ← All Projects
                </a>
            </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
            <div class="sticky top-24 space-y-5">

                <!-- Project Stats -->
                <div class="bg-white border border-slate-200 rounded-2xl p-5">
                    <h4 class="font-heading font-semibold text-slate-900 text-sm mb-4">Project Info</h4>
                    <dl class="space-y-3">
                        @if (!string.IsNullOrEmpty(Model.CategoryName ?? Model.Category?.Name))
                        {
                            <div>
                                <dt class="text-xs text-slate-400">Category</dt>
                                <dd><span class="tag-badge mt-0.5 inline-block">@(Model.CategoryName ?? Model.Category?.Name)</span></dd>
                            </div>
                        }
                        <div>
                            <dt class="text-xs text-slate-400">Created</dt>
                            <dd class="text-sm font-medium text-slate-700">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                        </div>
                        <div class="flex gap-4">
                            <div>
                                <dt class="text-xs text-slate-400">Views</dt>
                                <dd class="text-sm font-medium text-slate-700">@Model.ViewCount</dd>
                            </div>
                            <div>
                                <dt class="text-xs text-slate-400">Likes</dt>
                                <dd class="text-sm font-medium text-slate-700">@Model.LikeCount</dd>
                            </div>
                        </div>
                    </dl>
                </div>

                <!-- CTA -->
                <div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl p-5 text-white">
                    <h4 class="font-heading font-bold text-base mb-2">Like this project?</h4>
                    <p class="text-indigo-200 text-xs mb-4">Let's work together on something similar.</p>
                    <a asp-controller="Contact" asp-action="Index"
                       class="block text-center py-2.5 bg-white text-indigo-700 font-semibold rounded-lg text-sm hover:bg-indigo-50 transition-colors">
                        Hire Me
                    </a>
                </div>
            </div>
        </aside>
    </div>
</div>
