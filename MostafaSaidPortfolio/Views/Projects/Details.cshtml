@model Project
@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.Description;
}

<!-- Page Header with wave bottom -->
<section class="page-header">
    <div class="page-header-content max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Ambient blob -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
            <div class="absolute top-0 right-1/4 w-72 h-72 bg-indigo-500/10 rounded-full blur-3xl"></div>
        </div>
        <div class="relative">
            @if (!string.IsNullOrEmpty(Model.CategoryName ?? Model.Category?.Name))
            {
                <span class="inline-block tag-badge mb-4 border-indigo-400/30 bg-indigo-500/20 text-indigo-300 slide-up">
                    @(Model.CategoryName ?? Model.Category?.Name)
                </span>
            }
            <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white mb-4 slide-up delay-100">@Model.Title</h1>
            <div class="flex flex-wrap items-center gap-4 text-slate-400 text-sm slide-up delay-200">
                <span>@Model.CreatedAt.ToString("MMMM yyyy")</span>
                @if (Model.IsFeatured)
                {
                    <span class="px-2.5 py-0.5 bg-amber-400/20 border border-amber-400/30 text-amber-300 rounded-full text-xs font-semibold">★ Featured</span>
                }
                @if (Model.ViewCount > 0)
                {
                    <span class="flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        @Model.ViewCount views
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Wave → page content bg -->
    <div class="section-wave-bottom">
        <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path class="wave-fill-base" d="M0,40 C300,70 600,10 900,45 C1100,65 1300,15 1440,35 L1440,70 L0,70 Z"/>
        </svg>
    </div>
</section>

<!-- Project Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" style="background:var(--bg-base)">
    <div class="grid lg:grid-cols-3 gap-12">

        <!-- Main Content -->
        <div class="lg:col-span-2 observe-left">

            <!-- Image -->
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-8 rounded-2xl overflow-hidden shadow-lg border" style="border-color:var(--border)">
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="w-full h-64 sm:h-80 object-cover" />
                </div>
            }
            else
            {
                <div class="mb-8 h-52 rounded-2xl border flex items-center justify-center" style="background:var(--accent-bg);border-color:var(--accent-border)">
                    <div class="w-16 h-16 rounded-2xl shadow flex items-center justify-center" style="background:var(--bg-surface)">
                        <svg class="w-8 h-8" style="color:var(--accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                        </svg>
                    </div>
                </div>
            }

            <!-- Description -->
            <div class="prose max-w-none mb-8">
                @if (!string.IsNullOrEmpty(Model.LongDescription))
                {
                    <p class="text-lg leading-relaxed" style="color:var(--text-secondary)">@Model.LongDescription</p>
                }
                else
                {
                    <p class="text-lg leading-relaxed" style="color:var(--text-secondary)">@Model.Description</p>
                }
            </div>

            <!-- Tech Stack -->
            @if (Model.TechStackList.Any())
            {
                <div class="mb-8">
                    <h3 class="font-heading font-bold text-lg mb-4" style="color:var(--text-primary)">Technology Stack</h3>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var tech in Model.TechStackList)
                        {
                            <span class="detail-tech-chip">@tech</span>
                        }
                    </div>
                </div>
            }

            <!-- Actions -->
            <div class="flex flex-wrap gap-3 pt-6 border-t detail-border">
                @if (!string.IsNullOrEmpty(Model.LiveUrl))
                {
                    <a href="@Model.LiveUrl" target="_blank" rel="noopener" class="btn-primary">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        View Live Demo
                    </a>
                }
                @if (!string.IsNullOrEmpty(Model.GitHubUrl))
                {
                    <a href="@Model.GitHubUrl" target="_blank" rel="noopener" class="detail-action-btn">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                        View on GitHub
                    </a>
                }
                <a asp-action="Index" class="detail-action-btn">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    All Projects
                </a>
            </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1 observe-right">
            <div class="sticky top-24 space-y-5">

                <!-- Project Stats -->
                <div class="detail-sidebar-card">
                    <h4 class="detail-sidebar-title font-heading">Project Info</h4>
                    <dl class="space-y-3">
                        @if (!string.IsNullOrEmpty(Model.CategoryName ?? Model.Category?.Name))
                        {
                            <div>
                                <dt class="detail-sidebar-label">Category</dt>
                                <dd><span class="tag-badge mt-0.5 inline-block">@(Model.CategoryName ?? Model.Category?.Name)</span></dd>
                            </div>
                        }
                        <div>
                            <dt class="detail-sidebar-label">Created</dt>
                            <dd class="detail-sidebar-value">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                        </div>
                        <div class="flex gap-6">
                            <div>
                                <dt class="detail-sidebar-label">Views</dt>
                                <dd class="detail-sidebar-value">@Model.ViewCount</dd>
                            </div>
                            <div>
                                <dt class="detail-sidebar-label">Likes</dt>
                                <dd class="detail-sidebar-value">@Model.LikeCount</dd>
                            </div>
                        </div>
                    </dl>
                </div>

                <!-- CTA -->
                <div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl p-5 text-white shadow-lg shadow-indigo-500/20">
                    <h4 class="font-heading font-bold text-base mb-2">Like this project?</h4>
                    <p class="text-indigo-200 text-xs mb-4 leading-relaxed">Let's work together on something similar.</p>
                    <a asp-controller="Contact" asp-action="Index"
                       class="block text-center py-2.5 bg-white text-indigo-700 font-semibold rounded-lg text-sm hover:bg-indigo-50 transition-all duration-200 hover:-translate-y-0.5">
                        Hire Me
                    </a>
                </div>
            </div>
        </aside>
    </div>
</div>
