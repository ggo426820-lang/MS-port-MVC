@model IEnumerable<Project>

@{
    ViewData["Title"] = "Archived Projects";
}

<h2 class="mb-4 text-center display-6">Archived Projects</h2>

@if (!Model.Any())
{
    <p class="text-center text-muted">No archived projects.</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var project in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm hover-shadow">
                    <img src="@project.ThumbnailUrl" class="card-img-top" style="height:180px; object-fit:cover;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@project.Title</h5>
                        <p class="text-truncate">@project.Description</p>
                        <p class="text-muted"><small>Last updated: @project.UpdatedAt.ToShortDateString()</small></p>
                    </div>
                </div>
            </div>
        }
    </div>
}
