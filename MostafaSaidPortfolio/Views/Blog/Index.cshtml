@using MostafaSaidPortfolio.Models
@model IEnumerable<MostafaSaidPortfolio.Models.BlogPost>
@{
    ViewData["Title"] = "Blog";
}

<!-- Page Header -->
<section class="page-header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-indigo-400 font-semibold text-sm uppercase tracking-wider mb-3">Writing & Thoughts</p>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white mb-4">Blog</h1>
        <p class="text-slate-400 text-lg max-w-xl">Articles on .NET, PostgreSQL, web development, and software engineering best practices.</p>
    </div>
</section>

<!-- Blog Posts Grid -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    @if (Model != null && Model.Any())
    {
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var post in Model)
            {
                <a asp-action="Details" asp-route-id="@post.Id"
                   class="group bg-white rounded-2xl border border-slate-200 hover:border-indigo-200 p-6 shadow-sm hover:shadow-xl hover:shadow-indigo-100/50 transition-all duration-300 hover:-translate-y-1.5 flex flex-col">

                    @if (!string.IsNullOrEmpty(post.FeaturedImageUrl))
                    {
                        <div class="h-40 rounded-xl overflow-hidden mb-5 -mx-2">
                            <img src="@post.FeaturedImageUrl" alt="@post.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                        </div>
                    }

                    <div class="flex items-center justify-between mb-3">
                        @if (!string.IsNullOrEmpty(post.CategoryName ?? post.Category?.Name))
                        {
                            <span class="tag-badge">@(post.CategoryName ?? post.Category?.Name)</span>
                        }
                        <span class="text-slate-400 text-xs flex items-center gap-1">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            @post.EstimatedReadingTime min
                        </span>
                    </div>

                    <h2 class="font-heading font-bold text-slate-900 text-lg leading-snug mb-3 group-hover:text-indigo-600 transition-colors">
                        @post.Title
                    </h2>

                    @if (!string.IsNullOrEmpty(post.Summary))
                    {
                        <p class="text-slate-600 text-sm leading-relaxed mb-4 flex-1">
                            @(post.Summary.Length > 120 ? post.Summary.Substring(0, 120) + "…" : post.Summary)
                        </p>
                    }

                    <div class="flex items-center justify-between pt-4 border-t border-slate-100 text-xs text-slate-400">
                        <div class="flex items-center gap-2">
                            @if (!string.IsNullOrEmpty(post.AuthorName ?? post.Author?.Name))
                            {
                                <div class="w-6 h-6 rounded-full bg-gradient-to-br from-indigo-400 to-purple-400 flex items-center justify-center text-white text-xs font-bold">
                                    @((post.AuthorName ?? post.Author?.Name ?? "?")[0])
                                </div>
                                <span>@(post.AuthorName ?? post.Author?.Name)</span>
                            }
                        </div>
                        <span>@post.CreatedAt.ToString("MMM d, yyyy")</span>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="text-center py-24">
            <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-indigo-50 flex items-center justify-center">
                <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
            </div>
            <h3 class="font-heading font-bold text-slate-900 text-xl mb-2">No articles yet</h3>
            <p class="text-slate-500">Check back soon — articles are coming!</p>
        </div>
    }
</section>
