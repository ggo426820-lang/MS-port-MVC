@model IEnumerable<MostafaSaidPortfolio.Models.BlogPost>
@{
    ViewData["Title"] = "Blog";
}

<section class="container mx-auto px-6 py-16">
    <h2 class="text-3xl font-bold mb-8">All Blog Posts</h2>
    <div class="grid md:grid-cols-3 gap-8">
        @foreach (var post in Model)
        {
            <div class="bg-white rounded-lg shadow p-6 hover:shadow-lg transition">
                <h3 class="text-xl font-semibold mb-2">@post.Title</h3>
                <p class="text-gray-600 mb-4">@post.Summary</p>
                <a asp-action="Details" asp-route-id="@post.Id" class="text-indigo-600 font-semibold hover:underline">
                    Read More →
                </a>
            </div>
        }
    </div>
</section>
