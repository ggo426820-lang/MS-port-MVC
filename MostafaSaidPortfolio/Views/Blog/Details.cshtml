@model BlogPost
@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.MetaDescription.Length > 0 ? Model.MetaDescription : Model.Summary;
}

<!-- Article Header -->
<section class="page-header">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        @if (!string.IsNullOrEmpty(Model.CategoryName ?? Model.Category?.Name))
        {
            <span class="inline-block tag-badge mb-4 border-indigo-400/30 bg-indigo-500/20 text-indigo-300">
                @(Model.CategoryName ?? Model.Category?.Name)
            </span>
        }
        <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-5">
            @Model.Title
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-slate-400 text-sm">
            @if (!string.IsNullOrEmpty(Model.AuthorName ?? Model.Author?.Name))
            {
                <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-full bg-gradient-to-br from-indigo-400 to-purple-400 flex items-center justify-center text-white text-xs font-bold">
                        @((Model.AuthorName ?? Model.Author?.Name ?? "?")[0])
                    </div>
                    <span>@(Model.AuthorName ?? Model.Author?.Name)</span>
                </div>
            }
            <span>·</span>
            <span>@Model.CreatedAt.ToString("MMMM d, yyyy")</span>
            <span>·</span>
            <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                @Model.EstimatedReadingTime min read
            </span>
            <span>·</span>
            <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                @Model.ViewCount views
            </span>
        </div>
    </div>
</section>

<!-- Article Content -->
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-4 gap-12">

        <!-- Article Body -->
        <article class="lg:col-span-3">
            @if (!string.IsNullOrEmpty(Model.Summary))
            {
                <div class="bg-indigo-50 border-l-4 border-indigo-400 rounded-r-xl px-6 py-4 mb-8">
                    <p class="text-indigo-800 text-base leading-relaxed font-medium">@Model.Summary</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.FeaturedImageUrl))
            {
                <img src="@Model.FeaturedImageUrl" alt="@Model.Title"
                     class="w-full rounded-2xl shadow-md mb-8 object-cover max-h-80" />
            }

            <div class="prose max-w-none">
                @Html.Raw(Model.Content)
            </div>

            <div class="mt-12 pt-8 border-t border-slate-200 flex items-center justify-between">
                <a asp-action="Index" class="flex items-center gap-2 text-indigo-600 font-semibold hover:text-indigo-700">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    Back to Blog
                </a>
                <div class="flex items-center gap-2 text-slate-500 text-sm">
                    <span>Share:</span>
                    <a href="https://twitter.com/intent/tweet?text=@Uri.EscapeDataString(Model.Title)&url=@Uri.EscapeDataString(Context.Request.Path)"
                       target="_blank" class="px-3 py-1.5 bg-sky-50 text-sky-600 rounded-lg text-xs font-semibold hover:bg-sky-100 transition-colors">
                        Twitter/X
                    </a>
                    <a href="https://www.linkedin.com/shareArticle?mini=true&url=@Uri.EscapeDataString(Context.Request.Path)&title=@Uri.EscapeDataString(Model.Title)"
                       target="_blank" class="px-3 py-1.5 bg-blue-50 text-blue-600 rounded-lg text-xs font-semibold hover:bg-blue-100 transition-colors">
                        LinkedIn
                    </a>
                </div>
            </div>
        </article>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
            <div class="sticky top-24 space-y-6">

                <!-- Author Card -->
                @if (!string.IsNullOrEmpty(Model.AuthorName ?? Model.Author?.Name))
                {
                    <div class="bg-white border border-slate-200 rounded-2xl p-5">
                        <h4 class="font-heading font-semibold text-slate-900 text-sm mb-3">Written by</h4>
                        <div class="flex items-center gap-3">
                            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-indigo-400 to-purple-400 flex items-center justify-center text-white font-bold">
                                @((Model.AuthorName ?? Model.Author?.Name ?? "?")[0])
                            </div>
                            <div>
                                <div class="font-semibold text-slate-900 text-sm">@(Model.AuthorName ?? Model.Author?.Name)</div>
                                <div class="text-slate-500 text-xs">Full Stack Developer</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Article Info -->
                <div class="bg-white border border-slate-200 rounded-2xl p-5">
                    <h4 class="font-heading font-semibold text-slate-900 text-sm mb-4">Article Details</h4>
                    <dl class="space-y-3 text-sm">
                        <div>
                            <dt class="text-slate-400 text-xs">Published</dt>
                            <dd class="font-medium text-slate-700">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                        </div>
                        <div>
                            <dt class="text-slate-400 text-xs">Reading Time</dt>
                            <dd class="font-medium text-slate-700">@Model.EstimatedReadingTime min</dd>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.CategoryName ?? Model.Category?.Name))
                        {
                            <div>
                                <dt class="text-slate-400 text-xs">Category</dt>
                                <dd><span class="tag-badge">@(Model.CategoryName ?? Model.Category?.Name)</span></dd>
                            </div>
                        }
                    </dl>
                </div>

                <!-- CTA -->
                <div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl p-5 text-white">
                    <h4 class="font-heading font-bold text-base mb-2">Have a project?</h4>
                    <p class="text-indigo-200 text-xs mb-4">Let's build something great together.</p>
                    <a asp-controller="Contact" asp-action="Index"
                       class="block text-center py-2 bg-white text-indigo-700 font-semibold rounded-lg text-sm hover:bg-indigo-50 transition-colors">
                        Get In Touch
                    </a>
                </div>
            </div>
        </aside>
    </div>
</div>
