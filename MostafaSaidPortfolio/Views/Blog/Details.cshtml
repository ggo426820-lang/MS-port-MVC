@model BlogPost
@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.MetaDescription.Length > 0 ? Model.MetaDescription : Model.Summary;
}

<!-- Article Header with wave bottom -->
<section class="page-header">
    <div class="page-header-content max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Ambient blob -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
            <div class="absolute top-0 right-1/3 w-72 h-72 bg-purple-500/10 rounded-full blur-3xl"></div>
        </div>
        <div class="relative">
            @if (!string.IsNullOrEmpty(Model.CategoryName ?? Model.Category?.Name))
            {
                <span class="inline-block tag-badge mb-4 border-indigo-400/30 bg-indigo-500/20 text-indigo-300 slide-up">
                    @(Model.CategoryName ?? Model.Category?.Name)
                </span>
            }
            <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-5 slide-up delay-100">
                @Model.Title
            </h1>
            <div class="flex flex-wrap items-center gap-4 text-slate-400 text-sm slide-up delay-200">
                @if (!string.IsNullOrEmpty(Model.AuthorName ?? Model.Author?.Name))
                {
                    <div class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-full bg-gradient-to-br from-indigo-400 to-purple-400 flex items-center justify-center text-white text-xs font-bold">
                            @((Model.AuthorName ?? Model.Author?.Name ?? "?")[0])
                        </div>
                        <span>@(Model.AuthorName ?? Model.Author?.Name)</span>
                    </div>
                    <span class="text-slate-600">·</span>
                }
                <span>@Model.CreatedAt.ToString("MMMM d, yyyy")</span>
                <span class="text-slate-600">·</span>
                <span class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    @Model.EstimatedReadingTime min read
                </span>
                <span class="text-slate-600">·</span>
                <span class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    @Model.ViewCount views
                </span>
            </div>
        </div>
    </div>

    <!-- Wave → page content -->
    <div class="section-wave-bottom">
        <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path class="wave-fill-base" d="M0,35 C240,70 480,5 720,40 C960,70 1200,10 1440,35 L1440,70 L0,70 Z"/>
        </svg>
    </div>
</section>

<!-- Article Content -->
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16" style="background:var(--bg-base)">
    <div class="grid lg:grid-cols-4 gap-12">

        <!-- Article Body -->
        <article class="lg:col-span-3 observe-left">
            @if (!string.IsNullOrEmpty(Model.Summary))
            {
                <div class="blog-summary-block">
                    <p>@Model.Summary</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.FeaturedImageUrl))
            {
                <img src="@Model.FeaturedImageUrl" alt="@Model.Title"
                     class="w-full rounded-2xl shadow-md mb-8 object-cover max-h-80 border" style="border-color:var(--border)" />
            }

            <div class="prose max-w-none">
                @Html.Raw(Model.Content)
            </div>

            <div class="mt-12 pt-8 border-t detail-border flex items-center justify-between flex-wrap gap-4">
                <a asp-action="Index" class="detail-back-link">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    Back to Blog
                </a>
                <div class="flex items-center gap-2 text-sm" style="color:var(--text-muted)">
                    <span>Share:</span>
                    <a href="https://twitter.com/intent/tweet?text=@Uri.EscapeDataString(Model.Title)&url=@Uri.EscapeDataString(Context.Request.Path)"
                       target="_blank"
                       class="px-3 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 hover:-translate-y-0.5"
                       style="background:var(--bg-subtle);color:var(--accent)">
                        Twitter / X
                    </a>
                    <a href="https://www.linkedin.com/shareArticle?mini=true&url=@Uri.EscapeDataString(Context.Request.Path)&title=@Uri.EscapeDataString(Model.Title)"
                       target="_blank"
                       class="px-3 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 hover:-translate-y-0.5"
                       style="background:var(--bg-subtle);color:var(--accent)">
                        LinkedIn
                    </a>
                </div>
            </div>
        </article>

        <!-- Sidebar -->
        <aside class="lg:col-span-1 observe-right">
            <div class="sticky top-24 space-y-6">

                <!-- Author Card -->
                @if (!string.IsNullOrEmpty(Model.AuthorName ?? Model.Author?.Name))
                {
                    <div class="detail-sidebar-card">
                        <h4 class="detail-sidebar-title font-heading">Written by</h4>
                        <div class="flex items-center gap-3">
                            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-indigo-400 to-purple-400 flex items-center justify-center text-white font-bold shrink-0">
                                @((Model.AuthorName ?? Model.Author?.Name ?? "?")[0])
                            </div>
                            <div>
                                <div class="font-semibold text-sm" style="color:var(--text-primary)">@(Model.AuthorName ?? Model.Author?.Name)</div>
                                <div class="text-xs" style="color:var(--text-muted)">Full Stack Developer</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Article Info -->
                <div class="detail-sidebar-card">
                    <h4 class="detail-sidebar-title font-heading">Article Details</h4>
                    <dl class="space-y-3 text-sm">
                        <div>
                            <dt class="detail-sidebar-label">Published</dt>
                            <dd class="detail-sidebar-value">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                        </div>
                        <div>
                            <dt class="detail-sidebar-label">Reading Time</dt>
                            <dd class="detail-sidebar-value">@Model.EstimatedReadingTime min</dd>
                        </div>
                        <div>
                            <dt class="detail-sidebar-label">Views</dt>
                            <dd class="detail-sidebar-value">@Model.ViewCount</dd>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.CategoryName ?? Model.Category?.Name))
                        {
                            <div>
                                <dt class="detail-sidebar-label">Category</dt>
                                <dd class="mt-1"><span class="tag-badge">@(Model.CategoryName ?? Model.Category?.Name)</span></dd>
                            </div>
                        }
                    </dl>
                </div>

                <!-- CTA -->
                <div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl p-5 text-white shadow-lg shadow-indigo-500/20">
                    <h4 class="font-heading font-bold text-base mb-2">Have a project?</h4>
                    <p class="text-indigo-200 text-xs mb-4 leading-relaxed">Let's build something great together.</p>
                    <a asp-controller="Contact" asp-action="Index"
                       class="block text-center py-2.5 bg-white text-indigo-700 font-semibold rounded-lg text-sm hover:bg-indigo-50 transition-all duration-200 hover:-translate-y-0.5">
                        Get In Touch
                    </a>
                </div>
            </div>
        </aside>
    </div>
</div>
