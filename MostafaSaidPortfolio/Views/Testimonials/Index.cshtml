@model IEnumerable<MostafaSaidPortfolio.Domain.Entities.Testimonial>
@{
    ViewData["Title"] = L["Testimonials_Title"].ToString();
    var list = Model?.ToList() ?? new();
    var avgRating = list.Any() ? list.Average(t => t.Rating) : 0;
}

<!-- Page Header -->
<section class="page-header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-indigo-400 font-semibold text-xs uppercase tracking-widest mb-3">@L["Testimonials_Label"]</p>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white mb-4">@L["Testimonials_Title"]</h1>
        <p class="text-slate-400 text-lg max-w-xl">@L["Testimonials_Description"]</p>
    </div>
</section>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">

    @if (list.Any())
    {
        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-4 mb-14 max-w-lg">
            <div class="content-card p-5 text-center">
                <div class="font-heading text-3xl font-bold mb-1" style="color:var(--accent)">@list.Count</div>
                <div class="text-xs" style="color:var(--text-muted)">@L["Testimonials_Total"]</div>
            </div>
            <div class="content-card p-5 text-center">
                <div class="font-heading text-3xl font-bold mb-1" style="color:var(--accent)">@avgRating.ToString("F1")</div>
                <div class="text-xs" style="color:var(--text-muted)">@L["Testimonials_AvgRating"]</div>
            </div>
            <div class="content-card p-5 text-center">
                <div class="font-heading text-3xl font-bold mb-1" style="color:var(--accent)">@list.Count(t => t.Rating == 5)</div>
                <div class="text-xs" style="color:var(--text-muted)">@L["Testimonials_FiveStar"]</div>
            </div>
        </div>

        <!-- Grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
            @foreach (var t in list)
            {
                <div class="content-card p-6 flex flex-col observe-fade">
                    <!-- Stars -->
                    <div class="flex items-center gap-0.5 mb-4">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <svg class="w-4 h-4 @(i <= t.Rating ? "text-amber-400" : "text-slate-200 dark:text-slate-700") fill-current" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                        }
                        @if (t.IsFeatured)
                        {
                            <span class="ml-auto text-xs font-bold text-amber-500">@L["Common_Featured"]</span>
                        }
                    </div>

                    <!-- Quote -->
                    <blockquote class="flex-1 text-sm leading-relaxed italic mb-5" style="color:var(--text-secondary)">
                        "@t.Content"
                    </blockquote>

                    <!-- Author -->
                    <div class="flex items-center gap-3 pt-4 border-t card-divider">
                        @if (!string.IsNullOrEmpty(t.ImageUrl))
                        {
                            <img src="@t.ImageUrl" alt="@t.AuthorName"
                                 class="w-10 h-10 rounded-full object-cover shrink-0" />
                        }
                        else
                        {
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-400 to-purple-400 flex items-center justify-center text-white font-bold text-sm shrink-0">
                                @(t.AuthorName.Length > 0 ? t.AuthorName[0].ToString().ToUpper() : "?")
                            </div>
                        }
                        <div class="min-w-0">
                            <div class="font-semibold text-sm truncate" style="color:var(--text-primary)">@t.AuthorName</div>
                            <div class="text-xs truncate" style="color:var(--text-muted)">
                                @t.Position@(!string.IsNullOrEmpty(t.Company) ? " · " + t.Company : "")
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="content-card p-16 text-center mb-16">
            <svg class="w-12 h-12 mx-auto mb-4" style="color:var(--text-muted)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
            </svg>
            <p class="font-heading font-semibold text-lg mb-2" style="color:var(--text-primary)">@L["Testimonials_Empty"]</p>
            <p class="text-sm" style="color:var(--text-muted)">@L["Testimonials_EmptyDesc"]</p>
        </div>
    }

    <!-- CTA: Submit your own -->
    <div class="bg-gradient-to-br from-indigo-600 to-purple-700 rounded-2xl p-10 text-center text-white">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold mb-3">@L["Testimonials_CtaTitle"]</h2>
        <p class="text-indigo-200 mb-6 max-w-md mx-auto">@L["Testimonials_CtaDesc"]</p>
        <a asp-controller="Testimonials" asp-action="Submit"
           class="inline-flex items-center gap-2 px-7 py-3.5 bg-white text-indigo-700 font-bold rounded-xl hover:bg-indigo-50 transition-colors shadow-lg">
            @L["Testimonials_Submit"]
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
        </a>
    </div>
</div>
