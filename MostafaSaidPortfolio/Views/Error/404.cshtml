@{
    ViewData["Title"] = EL["Error_404_Title"].ToString();
}

<section class="min-h-[60vh] flex items-center justify-center px-4 py-24">
    <div class="max-w-lg text-center">

        <!-- Big number -->
        <div class="relative inline-block mb-8">
            <div class="font-heading font-bold select-none leading-none"
                 style="font-size:9rem;color:var(--accent-bg);letter-spacing:-0.04em">404</div>
            <div class="absolute inset-0 flex items-center justify-center">
                <svg class="w-20 h-20" style="color:var(--accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"
                          d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
        </div>

        <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-4" style="color:var(--text-primary)">
            @EL["Error_404_Title"]
        </h1>
        <p class="text-lg mb-10 leading-relaxed" style="color:var(--text-secondary)">
            @EL["Error_404_Description"]
        </p>

        <div class="flex flex-wrap justify-center gap-4">
            <a asp-controller="Home" asp-action="Index"
               class="inline-flex items-center gap-2 px-7 py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-all duration-200 hover:-translate-y-0.5 shadow-lg shadow-indigo-500/25">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                @EL["Error_404_GoHome"]
            </a>
            <button onclick="history.back()"
                    class="inline-flex items-center gap-2 px-7 py-3.5 font-semibold rounded-xl border transition-all duration-200 hover:-translate-y-0.5"
                    style="border-color:var(--border);color:var(--text-secondary)">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                @EL["Error_404_GoBack"]
            </button>
        </div>

        <div class="mt-12 pt-8 border-t flex justify-center gap-6 text-sm font-medium" style="border-color:var(--border);color:var(--accent)">
            <a asp-controller="Projects" asp-action="Index" class="hover:opacity-75 transition-opacity">@L["Nav_Projects"]</a>
            <a asp-controller="Blog"     asp-action="Index" class="hover:opacity-75 transition-opacity">@L["Nav_Blog"]</a>
            <a asp-controller="Contact"  asp-action="Index" class="hover:opacity-75 transition-opacity">@L["Nav_Contact"]</a>
        </div>
    </div>
</section>
