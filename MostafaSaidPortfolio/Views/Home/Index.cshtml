@{
    ViewData["Title"] = L["Nav_Home"].ToString();
    var projects     = ViewBag.Projects     as IEnumerable<Project>     ?? Array.Empty<Project>();
    var blogs        = ViewBag.Blogs        as IEnumerable<BlogPost>    ?? Array.Empty<BlogPost>();
    var testimonials = ViewBag.Testimonials as IEnumerable<Testimonial> ?? Array.Empty<Testimonial>();
}

<!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
<section class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-indigo-950 to-slate-900 text-white">
    <!-- Ambient blobs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/4 left-1/4 w-80 h-80 bg-indigo-500 rounded-full blur-3xl opacity-20 float-anim"></div>
        <div class="absolute bottom-1/3 right-1/4 w-96 h-96 bg-purple-600 rounded-full blur-3xl opacity-15" style="animation: float 5s ease-in-out infinite 1s"></div>
        <div class="absolute top-1/2 left-2/3 w-56 h-56 bg-violet-500 rounded-full blur-3xl opacity-10" style="animation: float 6s ease-in-out infinite 2s"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 lg:py-36">
        <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-indigo-500/20 border border-indigo-400/30 rounded-full text-indigo-300 text-sm font-medium mb-6 slide-up">
                <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                @L["Hero_Badge"]
            </div>
            <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-bold leading-tight mb-6 slide-up delay-100">
                @L["Hero_Hello"] <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">Mostafa Said</span>
            </h1>
            <p class="text-xl text-slate-300 leading-relaxed mb-10 max-w-2xl slide-up delay-200">
                @L["Hero_Description"]
            </p>
            <div class="flex flex-wrap gap-4 slide-up delay-300">
                <a asp-controller="Projects" asp-action="Index"
                   class="inline-flex items-center gap-2 px-7 py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-indigo-500/30 hover:shadow-indigo-500/50 hover:-translate-y-0.5">
                    @L["Hero_ViewWork"]
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <a asp-controller="Contact" asp-action="Index"
                   class="inline-flex items-center gap-2 px-7 py-3.5 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl border border-white/20 transition-all duration-200 hover:-translate-y-0.5">
                    @L["Hero_Contact"]
                </a>
            </div>
        </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
            <div class="slide-up delay-100">
                <div class="stat-number" data-count="5" data-suffix="+">5+</div>
                <div class="stat-label">@L["Stats_Projects"]</div>
            </div>
            <div class="slide-up delay-200">
                <div class="stat-number" data-count="3" data-suffix="+">3+</div>
                <div class="stat-label">@L["Stats_Years"]</div>
            </div>
            <div class="slide-up delay-300">
                <div class="stat-number" data-count="10" data-suffix="+">10+</div>
                <div class="stat-label">@L["Stats_Tech"]</div>
            </div>
            <div class="slide-up delay-400">
                <div class="stat-number" data-count="100" data-suffix="%">100%</div>
                <div class="stat-label">@L["Stats_Satisfaction"]</div>
            </div>
        </div>
    </div>

    <!-- Wave → Featured Projects (bg-base) -->
    <div class="section-wave-bottom">
        <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path class="wave-fill-base" d="M0,35 C180,70 360,0 540,35 C720,70 900,0 1080,35 C1260,70 1380,20 1440,35 L1440,70 L0,70 Z"/>
        </svg>
    </div>
</section>

<!-- ═══════════════════════════════ FEATURED PROJECTS ════════════════════════════ -->
<section class="pt-24 pb-10" style="background:var(--bg-base)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-12 section-head">
            <div>
                <p class="section-label mb-2">@L["Home_PortfolioLabel"]</p>
                <h2 class="section-title font-heading">@L["Home_FeaturedProjects"]</h2>
            </div>
            <a asp-controller="Projects" asp-action="Index"
               class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold hover:opacity-80 transition-opacity"
               style="color:var(--accent)">
                @L["Home_ViewAll"]
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
        </div>

        @if (projects.Any())
        {
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
                @foreach (var project in projects)
                {
                    <div class="content-card group flex flex-col observe-fade">
                        <div class="relative h-44 overflow-hidden" style="background:linear-gradient(135deg,var(--accent-bg),#f3e8ff)">
                            @if (!string.IsNullOrEmpty(project.ImageUrl))
                            {
                                <img src="@project.ImageUrl" alt="@project.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                            }
                            else
                            {
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="w-16 h-16 rounded-2xl shadow-md flex items-center justify-center" style="background:var(--bg-surface)">
                                        <svg class="w-8 h-8" style="color:var(--accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                                        </svg>
                                    </div>
                                </div>
                            }
                            @if (project.IsFeatured)
                            {
                                <span class="absolute top-3 left-3 px-2.5 py-1 bg-amber-400 text-amber-900 text-xs font-bold rounded-full">@L["Common_Featured"]</span>
                            }
                            @if (!string.IsNullOrEmpty(project.CategoryName))
                            {
                                <span class="absolute top-3 right-3 px-2.5 py-1 bg-white/90 backdrop-blur-sm text-indigo-700 text-xs font-semibold rounded-full">@project.CategoryName</span>
                            }
                        </div>

                        <div class="p-6 flex flex-col flex-1">
                            <h3 class="card-title font-heading font-bold text-lg leading-tight mb-2 group-hover:text-indigo-500 transition-colors">@project.Title</h3>
                            <p class="card-text text-sm leading-relaxed mb-4 flex-1">@project.Description</p>

                            @if (project.TechStackList.Any())
                            {
                                <div class="flex flex-wrap gap-1.5 mb-4">
                                    @foreach (var tech in project.TechStackList.Take(4))
                                    {
                                        <span class="tech-chip">@tech</span>
                                    }
                                </div>
                            }

                            <div class="flex items-center gap-3 pt-4 border-t card-divider">
                                @if (!string.IsNullOrEmpty(project.LiveUrl))
                                {
                                    <a href="@project.LiveUrl" target="_blank" rel="noopener"
                                       class="flex-1 text-center px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold rounded-lg transition-colors">@L["Projects_LiveDemo"]</a>
                                }
                                @if (!string.IsNullOrEmpty(project.GitHubUrl))
                                {
                                    <a href="@project.GitHubUrl" target="_blank" rel="noopener"
                                       class="flex items-center gap-1.5 px-4 py-2 text-xs font-semibold rounded-lg transition-colors border"
                                       style="border-color:var(--border);color:var(--text-secondary)">
                                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                                        GitHub
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center py-16" style="color:var(--text-muted)">@L["Home_NoProjects"]</p>
        }
        <div class="sm:hidden text-center mt-8">
            <a asp-controller="Projects" asp-action="Index" class="inline-flex items-center gap-1.5 font-semibold text-sm" style="color:var(--accent)">
                @L["Home_ViewAll"] →
            </a>
        </div>
    </div>
</section>

<!-- Wave: bg-base → bg-surface (Skills) -->
<div class="wave-divider" style="background:var(--bg-base)">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path class="wave-fill-surface" d="M0,20 C320,70 640,0 960,40 C1120,60 1300,10 1440,30 L1440,70 L0,70 Z"/>
    </svg>
</div>

<!-- ════════════════════════════════ SKILLS ════════════════════════════════════ -->
<section class="py-16 skills-section" style="background:var(--bg-surface)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-center text-xs font-bold uppercase tracking-widest mb-8 section-head" style="color:var(--text-muted)">@L["Home_TechTitle"]</p>
        <div class="flex flex-wrap justify-center gap-3 skills-pills-container">
            @foreach (var skill in new[] { "ASP.NET Core", "C#", "PostgreSQL", "Dapper", "Entity Framework", "JavaScript", "TypeScript", "Tailwind CSS", "jQuery", "Git", "Docker", "REST APIs", "SQL", "HTML/CSS" })
            {
                <span class="skill-pill">@skill</span>
            }
        </div>
    </div>
</section>

<!-- Wave: bg-surface → bg-subtle (Blog) -->
<div class="wave-divider" style="background:var(--bg-surface)">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path class="wave-fill-subtle" d="M0,50 C200,10 400,70 600,30 C800,0 1000,60 1200,35 C1320,20 1400,50 1440,40 L1440,70 L0,70 Z"/>
    </svg>
</div>

<!-- ════════════════════════════════ LATEST BLOG ═══════════════════════════════ -->
<section class="py-24" style="background:var(--bg-subtle)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-12 section-head">
            <div>
                <p class="section-label mb-2">@L["Home_WritingLabel"]</p>
                <h2 class="section-title font-heading">@L["Home_LatestArticles"]</h2>
            </div>
            <a asp-controller="Blog" asp-action="Index"
               class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold hover:opacity-80 transition-opacity"
               style="color:var(--accent)">
                @L["Home_ViewAll"]
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
        </div>

        @if (blogs.Any())
        {
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
                @foreach (var post in blogs)
                {
                    <a asp-controller="Blog" asp-action="Details" asp-route-id="@post.Slug"
                       class="content-card group p-6 flex flex-col observe-fade" style="display:flex">
                        <div class="flex items-center justify-between mb-4">
                            @if (!string.IsNullOrEmpty(post.CategoryName))
                            {
                                <span class="tag-badge">@post.CategoryName</span>
                            }
                            <span class="text-xs flex items-center gap-1" style="color:var(--text-muted)">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                @post.EstimatedReadingTime @L["Blog_MinRead"]
                            </span>
                        </div>
                        <h3 class="card-title font-heading font-bold text-lg leading-snug mb-3 group-hover:text-indigo-500 transition-colors">@post.Title</h3>
                        <p class="card-text text-sm leading-relaxed mb-4 flex-1">
                            @(post.Summary.Length > 120 ? post.Summary[..120] + "…" : post.Summary)
                        </p>
                        <div class="flex items-center justify-between pt-4 border-t card-divider text-xs">
                            <span style="color:var(--text-muted)">@post.CreatedAt.ToString("MMM d, yyyy")</span>
                            <span class="font-semibold flex items-center gap-1 transition-all" style="color:var(--accent)">
                                @L["Home_ReadMore"] →
                            </span>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <p class="text-center py-16" style="color:var(--text-muted)">@L["Home_NoArticles"]</p>
        }
    </div>
</section>

<!-- Wave: bg-subtle → bg-base (Testimonials or Newsletter) -->
<div class="wave-divider" style="background:var(--bg-subtle)">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path class="wave-fill-base" d="M0,30 C360,70 720,0 1080,40 C1200,55 1340,15 1440,28 L1440,70 L0,70 Z"/>
    </svg>
</div>

<!-- ════════════════════════════════ TESTIMONIALS ═════════════════════════════ -->
@if (testimonials.Any())
{
    <section class="py-24" style="background:var(--bg-base)">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16 section-head">
                <p class="section-label mb-3">@L["Home_TestimonialsLabel"]</p>
                <h2 class="section-title font-heading">@L["Home_WhatClientsSay"]</h2>
                <div class="mx-auto mt-4 w-12 h-1 rounded-full" style="background:var(--accent); opacity:0.6"></div>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
                @foreach (var t in testimonials)
                {
                    <div class="testimonial-card observe-fade">
                        <div class="testimonial-quote">&ldquo;</div>

                        <div class="flex gap-0.5 mb-4 relative z-10">
                            @for (int i = 0; i < Math.Min(t.Rating, 5); i++)
                            {
                                <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            }
                        </div>

                        <p class="testimonial-text">@t.Content</p>

                        <div class="testimonial-author">
                            <div class="testimonial-avatar">
                                @(t.AuthorName.Length > 0 ? t.AuthorName.Substring(0, 1).ToUpper() : "?")
                            </div>
                            <div class="min-w-0">
                                <div class="testimonial-name">@t.AuthorName</div>
                                @if (!string.IsNullOrEmpty(t.Company))
                                {
                                    <div class="testimonial-company">@t.Company</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Wave: bg-base → Newsletter indigo -->
    <div class="wave-divider" style="background:var(--bg-base)">
        <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path fill="#4f46e5" d="M0,45 C240,10 480,70 720,35 C960,0 1200,60 1440,30 L1440,70 L0,70 Z"/>
        </svg>
    </div>
}
else
{
    <!-- Wave: bg-base → Newsletter indigo (no testimonials) -->
    <div class="wave-divider" style="background:var(--bg-base)">
        <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path fill="#4f46e5" d="M0,45 C240,10 480,70 720,35 C960,0 1200,60 1440,30 L1440,70 L0,70 Z"/>
        </svg>
    </div>
}

<!-- ════════════════════════════════ NEWSLETTER ═══════════════════════════════ -->
<section class="relative overflow-hidden pt-20 pb-0" style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%)">
    <!-- Subtle orbs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-12 -right-12 w-64 h-64 bg-white/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 -left-12 w-80 h-80 bg-indigo-800/30 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center pb-20">
        <div class="section-head">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 border border-white/20 rounded-full text-indigo-200 text-xs font-semibold mb-5">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Newsletter
            </div>
            <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-4">@L["Home_NewsletterTitle"]</h2>
            <p class="text-indigo-200 text-lg mb-8">@L["Home_NewsletterDesc"]</p>
        </div>
        <form asp-controller="Newsletter" asp-action="Subscribe" method="post" data-newsletter
              class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto observe-scale">
            @Html.AntiForgeryToken()
            <input type="email" name="email" placeholder="@L["Home_EmailPlaceholder"]"
                   class="flex-1 px-5 py-3.5 rounded-xl bg-white/10 border border-white/30 text-white placeholder-indigo-300 focus:outline-none focus:ring-2 focus:ring-white/50 text-sm" required />
            <button type="submit"
                    class="px-6 py-3.5 bg-white text-indigo-700 font-bold rounded-xl hover:bg-indigo-50 transition-all duration-200 hover:-translate-y-0.5 text-sm whitespace-nowrap shadow-lg">
                @L["Home_Subscribe"]
            </button>
        </form>
    </div>

    <!-- Wave → Footer -->
    <div class="section-wave-bottom">
        <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path class="wave-fill-footer" d="M0,25 C300,70 600,0 900,40 C1080,60 1280,10 1440,30 L1440,70 L0,70 Z"/>
        </svg>
    </div>
</section>
