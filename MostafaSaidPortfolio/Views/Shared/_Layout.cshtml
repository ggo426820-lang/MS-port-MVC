@using MostafaSaidPortfolio.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Mostafa Said Portfolio</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- SEO Structured Data -->
    <partial name="Partials/_JsonLdPartial" />

    @RenderSection("HeadContent", required: false)
</head>
<body class="flex flex-col min-h-screen text-gray-800">

    <!-- Header -->
    <header class="bg-white shadow">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a asp-controller="Home" asp-action="Index" class="text-xl font-bold text-indigo-600">Portfolio</a>

            <nav class="flex space-x-6">
                <a asp-controller="Home" asp-action="Index" class="hover:text-indigo-600">Home</a>
                <a asp-controller="Projects" asp-action="Index" class="hover:text-indigo-600">Projects</a>
                <a asp-controller="Blog" asp-action="Index" class="hover:text-indigo-600">Blog</a>
                <a asp-controller="Contact" asp-action="Index" class="hover:text-indigo-600">Contact</a>
            </nav>

            <!-- Localization Switch -->
            <partial name="Partials/_LocalizationPartial" />
        </div>
    </header>

    <!-- Breadcrumb -->
    <div class="container mx-auto px-6 mt-4">
        <partial name="Partials/_BreadcrumbPartial" model="ViewBag.Breadcrumbs" />
    </div>

    <!-- Main -->
    <main class="container mx-auto flex-1 px-6 py-10">
        @RenderBody()
    </main>

    <!-- Extra sections (Skills, Testimonials, Subscribe, etc.) -->
    <section class="container mx-auto px-6 space-y-12">
        <partial name="Partials/_SkillsPartial" model="ViewBag.Skills" />
        <partial name="Partials/_TestimonialsPartial" model="ViewBag.Testimonials" />
        <partial name="Partials/_SubscribePartial" />
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 py-10 mt-16">
        <div class="container mx-auto px-6 grid md:grid-cols-3 gap-10">
            <div>
                <h4 class="font-semibold text-white mb-4">About</h4>
                <p class="text-sm">Mostafa Said Portfolio – showcasing projects, blogs, and skills.</p>
            </div>

            <div>
                <h4 class="font-semibold text-white mb-4">Contact</h4>
                <partial name="Partials/_ContactInfoPartial" />
            </div>

            <div>
                <h4 class="font-semibold text-white mb-4">Follow</h4>
                <partial name="Partials/_SocialLinksPartial" />
            </div>
        </div>
        <div class="mt-10 text-center text-sm text-gray-500">
            © @DateTime.UtcNow.Year Mostafa Said. All rights reserved.
        </div>
    </footer>

    <!-- Always-loaded Partials -->
    <partial name="Partials/_CookieConsentPartial" />
    <partial name="Partials/_LoadingPartial" />

    @RenderSection("Scripts", required: false)
</body>
</html>
