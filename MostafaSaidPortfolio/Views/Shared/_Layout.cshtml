@using System.Globalization
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var isRtl    = CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var langCode = isRtl ? "ar" : "en";
    var dir      = isRtl ? "rtl" : "ltr";
    var returnUrl = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);
}
<!DOCTYPE html>
<html lang="@langCode" dir="@dir" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — Mostafa Said</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Mostafa Said — Full Stack Developer.")" />

    <!-- Anti-FOUC: apply saved theme BEFORE first paint -->
    <script>
        (function () {
            var t = 'light';
            try { t = localStorage.getItem('ms-theme') || 'light'; } catch (_) {}
            document.documentElement.classList.toggle('dark', t === 'dark');
            document.documentElement.setAttribute('data-theme', t);
        }());
    </script>

    <!-- Fonts: Almendra (body) + Quintessential (heading) + Noto Sans Arabic (RTL) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Almendra:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quintessential&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Tailwind CSS (dark-mode via class) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans:    ['Almendra', 'Noto Sans Arabic', 'Georgia', 'serif'],
                        heading: ['Quintessential', 'Almendra', 'Noto Sans Arabic', 'Georgia', 'serif'],
                    },
                    colors: {
                        primary: {
                            DEFAULT: '#6366f1',
                            dark:    '#4f46e5',
                            light:   '#818cf8',
                            50:      '#eef2ff',
                            100:     '#e0e7ff',
                        },
                    },
                }
            }
        }
    </script>

    <!-- Custom styles -->
    <link rel="stylesheet" href="~/css/site.css" />

    @RenderSection("HeadContent", required: false)
</head>
<body class="font-sans antialiased flex flex-col min-h-screen transition-colors duration-300"
      style="background:var(--bg-base);color:var(--text-primary)">

    <!-- Page-transition cover — fades out on load, fades in on lang switch -->
    <div id="page-cover" aria-hidden="true"></div>

    <!-- ===================== HEADER ===================== -->
    <header id="site-header" class="sticky top-0 z-50 backdrop-blur-md border-b transition-all duration-300"
            style="background:var(--header-bg);border-color:var(--header-border)">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16 gap-4">

                <!-- Logo -->
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2.5 group shrink-0">
                    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-md group-hover:shadow-indigo-400/40 transition-shadow">
                        <span class="text-white font-heading font-bold text-sm">MS</span>
                    </div>
                    <span class="font-heading font-bold text-lg hidden sm:block" style="color:var(--text-primary)">Mostafa Said</span>
                </a>

                <!-- Desktop Nav -->
                <nav class="hidden md:flex items-center gap-0.5 flex-1 justify-center">
                    <a asp-controller="Home"     asp-action="Index" class="nav-link">@L["Nav_Home"]</a>
                    <a asp-controller="Projects" asp-action="Index" class="nav-link">@L["Nav_Projects"]</a>
                    <a asp-controller="Blog"     asp-action="Index" class="nav-link">@L["Nav_Blog"]</a>
                    <a asp-controller="Contact"  asp-action="Index" class="nav-link">@L["Nav_Contact"]</a>
                </nav>

                <!-- Right Controls -->
                <div class="flex items-center gap-2 shrink-0">

                    <!-- Language Toggle -->
                    <div class="lang-toggle hidden sm:flex">
                        <a href="/Culture/Set?culture=en&returnUrl=@returnUrl"
                           class="lang-btn" data-lang="en" title="English">EN</a>
                        <span class="lang-divider"></span>
                        <a href="/Culture/Set?culture=ar&returnUrl=@returnUrl"
                           class="lang-btn" data-lang="ar" title="العربية">AR</a>
                    </div>

                    <!-- Theme Toggle -->
                    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" type="button">
                        <!-- Moon (shown in light mode) -->
                        <svg id="icon-moon" class="w-4.5 h-4.5" style="width:1.125rem;height:1.125rem" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                        </svg>
                        <!-- Sun (shown in dark mode) -->
                        <svg id="icon-sun" class="w-4.5 h-4.5 hidden" style="width:1.125rem;height:1.125rem" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
                        </svg>
                    </button>

                    <!-- Hire Me (desktop) -->
                    <a asp-controller="Contact" asp-action="Index"
                       class="hidden sm:inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 dark:bg-indigo-500 dark:hover:bg-indigo-400 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-indigo-500/40 hover:-translate-y-0.5">
                        @L["Nav_HireMe"]
                    </a>

                    <!-- Hamburger -->
                    <button id="menu-toggle" class="md:hidden p-2 rounded-lg transition-colors" style="color:var(--text-secondary)"
                            aria-label="Toggle menu" type="button">
                        <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden border-t" style="border-color:var(--border)">
            <nav class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1">
                <a asp-controller="Home"     asp-action="Index" class="mobile-nav-link">@L["Nav_Home"]</a>
                <a asp-controller="Projects" asp-action="Index" class="mobile-nav-link">@L["Nav_Projects"]</a>
                <a asp-controller="Blog"     asp-action="Index" class="mobile-nav-link">@L["Nav_Blog"]</a>
                <a asp-controller="Contact"  asp-action="Index" class="mobile-nav-link">@L["Nav_Contact"]</a>

                <!-- Mobile: language + theme row -->
                <div class="flex items-center justify-between pt-3 border-t mt-1" style="border-color:var(--border)">
                    <div class="lang-toggle flex">
                        <a href="/Culture/Set?culture=en&returnUrl=@returnUrl" class="lang-btn" data-lang="en">EN</a>
                        <span class="lang-divider"></span>
                        <a href="/Culture/Set?culture=ar&returnUrl=@returnUrl" class="lang-btn" data-lang="ar">AR</a>
                    </div>
                    <button id="theme-toggle-mobile" onclick="ThemeManager.apply(document.documentElement.classList.contains('dark')?'light':'dark')"
                            class="theme-toggle" aria-label="Toggle theme" type="button">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                        </svg>
                    </button>
                </div>

                <div class="pt-1">
                    <a asp-controller="Contact" asp-action="Index"
                       class="block text-center px-4 py-2.5 bg-indigo-600 text-white font-semibold rounded-lg text-sm hover:bg-indigo-500 transition-colors">
                        @L["Nav_HireMe"]
                    </a>
                </div>
            </nav>
        </div>
    </header>

    <!-- ===================== MAIN ===================== -->
    <main class="flex-1">
        @RenderBody()
    </main>

    <!-- ===================== FOOTER ===================== -->
    <footer class="text-slate-300 pt-16 pb-8" style="background:var(--footer-bg)">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-3 gap-12 mb-12">

                <!-- Brand -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
                            <span class="text-white font-heading font-bold text-sm">MS</span>
                        </div>
                        <span class="font-heading font-bold text-white text-lg">Mostafa Said</span>
                    </div>
                    <p class="text-sm text-slate-400 leading-relaxed">@L["Footer_Bio"]</p>
                    <div class="flex gap-3 mt-5">
                        <a href="https://github.com/mostafasaid" target="_blank" rel="noopener" class="social-link" title="GitHub">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                        </a>
                        <a href="https://linkedin.com/in/mostafasaid" target="_blank" rel="noopener" class="social-link" title="LinkedIn">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        </a>
                        <a href="mailto:mostafa@example.com" class="social-link" title="Email">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div>
                    <h4 class="font-heading font-semibold text-white mb-4">@L["Footer_QuickLinks"]</h4>
                    <ul class="space-y-2.5 text-sm">
                        <li><a asp-controller="Home"     asp-action="Index" class="footer-link">@L["Nav_Home"]</a></li>
                        <li><a asp-controller="Projects" asp-action="Index" class="footer-link">@L["Nav_Projects"]</a></li>
                        <li><a asp-controller="Blog"     asp-action="Index" class="footer-link">@L["Nav_Blog"]</a></li>
                        <li><a asp-controller="Contact"  asp-action="Index" class="footer-link">@L["Nav_Contact"]</a></li>
                    </ul>
                </div>

                <!-- Contact Info -->
                <div>
                    <h4 class="font-heading font-semibold text-white mb-4">@L["Footer_GetInTouch"]</h4>
                    <ul class="space-y-3 text-sm text-slate-400">
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            mostafa@example.com
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            Cairo, Egypt
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                            @L["Footer_Available"]
                        </li>
                    </ul>
                </div>
            </div>

            <div class="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
                <p>© @DateTime.UtcNow.Year Mostafa Said. @L["Footer_Rights"]</p>
                <p>@L["Footer_BuiltWith"]</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
