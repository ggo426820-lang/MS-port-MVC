    {
        ""@context"": ""https://schema.org"",
        ""@type"": ""Person"",
        ""name"": ""Mostafa Said"",
        ""url"": ""https://yourdomain.com"",
        ""sameAs"": [
            ""https://twitter.com/yourprofile"",
            ""https://github.com/yourprofile"",
            ""https://linkedin.com/in/yourprofile""
        ],
        ""jobTitle"": ""Software Engineer"",
        ""worksFor"": {
            ""@type"": ""Organization"",
