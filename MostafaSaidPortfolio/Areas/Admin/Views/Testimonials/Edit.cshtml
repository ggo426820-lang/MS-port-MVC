@model MostafaSaidPortfolio.Domain.Entities.Testimonial
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Testimonial";
}

<div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-bold text-white">Edit Testimonial</h2>
    <a href="/Admin/Testimonials" class="btn-ghost">← Back</a>
</div>

<div class="max-w-2xl">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id"/>

        <div class="stat-card space-y-4">
            <div class="grid sm:grid-cols-2 gap-4">
                <div>
                    <label class="form-label">Author Name *</label>
                    <input asp-for="AuthorName" class="form-input" required/>
                </div>
                <div>
                    <label class="form-label">Position / Role *</label>
                    <input asp-for="Position" class="form-input" required/>
                </div>
                <div>
                    <label class="form-label">Company</label>
                    <input asp-for="Company" class="form-input"/>
                </div>
                <div>
                    <label class="form-label">Rating (1–5)</label>
                    <input asp-for="Rating" type="number" min="1" max="5" class="form-input" required/>
                </div>
                <div>
                    <label class="form-label">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" min="0" class="form-input"/>
                </div>
                <div>
                    <label class="form-label">Image URL</label>
                    <input asp-for="ImageUrl" class="form-input" placeholder="https://..."/>
                </div>
            </div>
            <div>
                <label class="form-label">Review Content *</label>
                <textarea asp-for="Content" class="form-input" rows="4" required></textarea>
            </div>
            <div class="flex gap-6">
                <div class="flex items-center gap-2">
                    <input asp-for="IsApproved" type="checkbox" id="IsApproved" class="rounded" @(Model.IsApproved ? "checked" : "")/>
                    <label for="IsApproved" class="text-sm text-slate-300">Approved</label>
                </div>
                <div class="flex items-center gap-2">
                    <input asp-for="IsFeatured" type="checkbox" id="IsFeatured" class="rounded" @(Model.IsFeatured ? "checked" : "")/>
                    <label for="IsFeatured" class="text-sm text-slate-300">Featured</label>
                </div>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="btn-primary">Save Changes</button>
            <a href="/Admin/Testimonials" class="btn-ghost">Cancel</a>
        </div>
    </form>
</div>
