@model MostafaSaidPortfolio.Domain.Entities.Project
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Project";
}

<div class="max-w-lg mx-auto">
    <div class="stat-card text-center py-10">
        <div class="w-14 h-14 bg-red-500/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
        </div>
        <h2 class="text-lg font-bold text-white mb-2">Delete Project?</h2>
        <p class="text-slate-400 text-sm mb-1"><span class="text-white font-medium">@Model.Title</span></p>
        <p class="text-slate-500 text-xs mb-6">This soft-deletes the project. It won't appear publicly.</p>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex justify-center gap-3">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-danger">Yes, Delete</button>
            <a href="/Admin/Projects" class="btn-ghost">Cancel</a>
        </form>
    </div>
</div>
